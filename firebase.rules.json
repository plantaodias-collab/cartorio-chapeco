{
  "rules": {
    ".read": false,
    ".write": false,
    "kanban": {
      ".read": true,
      "newCards": {
        "$cardId": {
          ".write": true,
          ".validate": "newData.hasChildren(['id', 'descricao', 'situacao', 'priority', 'aba']) && newData.child('id').isString()"
        }
      },
      "overrides": {
        "$cardId": {
          ".write": true,
          ".validate": "newData.hasChildren(['id', 'situacao', 'priority']) && newData.child('id').isString()"
        }
      },
      "audit": {
        "$entryId": {
          ".write": "!data.exists()",
          ".validate": "newData.hasChildren(['id', 'type', 'savedAt'])"
        }
      }
    }
  }
}
